# Uncomment here and at the bottom to enable zprof profiling
# zmodload zsh/zprof

# Smarter completion initialization
autoload -Uz compinit
if [ "$(date +'%j')" != "$(stat -f '%Sm' -t '%j' ~/.zcompdump 2>/dev/null)" ]; then
    compinit
else
    compinit -C
fi

path+=("$HOME/.local/bin")
path+=("$HOME/.cargo/bin")
path+=("$$HOME/.maestro/bin")

path+=("$HOME/.zshcustom/shellscripts")

# init rbenv and go if installed
if  type "rbenv" > /dev/null; then
    path+=("$HOME/.rbenv/bin")
    eval "$(rbenv init - zsh)"
fi

if  type "go" > /dev/null; then
    path+=("$(go env GOPATH)/bin")
fi

path+=("$HOME/Library/Android/sdk/platform-tools")
path+=("$HOME/Library/Android/sdk/emulator")
export ANDROID_HOME=~/Library/Android/sdk
export ANDROID_SDK_ROOT=~/Library/Android/sdk
export ANDROID_AVD_HOME=~/.android/avd

export EDITOR=nvim
export REACT_EDITOR=webstorm

export DOCKER_CLI_HINTS=false
export HOMEBREW_NO_ANALYTICS=1

# Only source nvm on the first node command
export NVM_LAZY_LOAD=true
export NVM_AUTO_USE=true
# Extra commands to trigger nvm load
export NVM_LAZY_LOAD_EXTRA_COMMANDS=('just' 'make' 'claude' 'pi' 'opencode')

# Plugins (source before custom config to avoid global alias conflicts)
source $(brew --prefix)/opt/zsh-vi-mode/share/zsh-vi-mode/zsh-vi-mode.plugin.zsh
source $HOME/.zshcustom/plugins/zsh-nvm/zsh-nvm.plugin.zsh
source $HOME/.zshcustom/plugins/zsh-autosuggestions/zsh-autosuggestions.plugin.zsh
source $HOME/.zshcustom/plugins/sublime-merge/sublime-merge.plugin.zsh

# Source custom config files
for config_file ($HOME/.zshcustom/*.zsh(N)); do
  source $config_file
done

# Start the ssh-agent if it's not running
if [ -z "$SSH_AUTH_SOCK" ]; then
    eval "$(ssh-agent -s)"
fi
# Add your SSH key to the agent if it's not already added
if ! ssh-add -l &>/dev/null; then
    ssh-add ~/.ssh/id_ed25519
fi

export DOCKER_BUILDKIT=1

# Prompt
eval "$(starship init zsh)"

# zprof
